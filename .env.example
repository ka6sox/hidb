# ENVIRONMENT=development
ENVIRONMENT=production
HOST=0.0.0.0
PORT=4000

# Optional: provide your own Flask session signing key. If unset, HIDB generates
# a per-install key under the Flask instance folder.
# SECRET_KEY=replace-with-a-long-random-string

# Set true when serving HIDB over HTTPS so browsers only send session cookies
# over secure connections.
# SESSION_COOKIE_SECURE=false

# Optional: PostgreSQL (or any SQLAlchemy-supported server). If unset, SQLite is used
# under the Flask instance path (see Flask docs). RDS / Aurora use the same URL shape.
# DATABASE_URL=postgresql://user:password@host:5432/hidb
