{% extends 'base.html.j2' %}

{% block header %}
<h1>{% block title %}Edit "{{ item['name'] }}"{% endblock %}</h1>
{% endblock %}

{% block content %}
{% if places|length < 1 %} You have not defined any places yet. <a href="{{ url_for('places.create') }}">Add a place first</a>.
{% else %}
  <form method="post" enctype="multipart/form-data">
    <table class="table table-borderless table-dark">
      <tr>
        <td><label for="name">Make/Model:</label></td>
        <td><input name="name" autofocus="autofocus" id="name" value="{{ request.form.get('name', item['name']) }}" required>
        </td>
      </tr>
      <tr>
        <td><label for="serial_no">Serial #:</label></td>
        <td><input name="serial_no" autocomplete="off" id="serial_no" value="{{ request.form.get('serial_no', item['serial_no'] or '') }}"></td>
      </tr>
      <tr>
        <td>
          <label for="qty">Quantity:</label>
        </td>
        <td>
          <input name="qty" id="qty" type="number" value="{{ request.form.get('qty', item['qty']) }}" required>
        </td>
      </tr>
      <tr>
        <td>
          <label for="cost">Cost:</label>
        </td>
        <td>
          <input name="cost" class="currency" id="cost" type="number" min="0.01" step="0.01" value="{% if request.form.get('cost') or (item['cost'] is string and item['cost']) or (item['cost'] is float and item['cost'] > 0.0) %}{{ '%.2f'|format(request.form.get('cost') or item['cost']) }}{% endif %}">
        </td>
      </tr>
      <tr>
        <td>
          <label for="place_id">Place:</label>
        </td>
        <td>
          <select name="place_id" id="place_id" required>
            {% for p in places %}
            <option value="{{ p.id }}" {% if item and p.id == item['place_id'] %}selected{% endif %}>{{ p.label }}</option>
            {% endfor %}
          </select>
          <br />
          <a class="action" href="{{ url_for('places.create') }}">Add a place</a>
        </td>
      </tr>
      <tr>
        <td>
          <label for="sublocation">Sublocation:</label>
        </td>
        <td>
          <input name="sublocation" id="sublocation" value="{{ request.form.get('sublocation', item['sublocation'] or '') }}">
          <br />
          <span class="text-muted small">Optional detail inside the selected place, such as "on top of the dongle".</span>
        </td>
      </tr>
      <tr>
        <td>
          <label for="tags">Tags:</label>
        </td>
        <td>
          <input name="tags" id="tags" value="{{ request.form.get('tags', item['tag_list']) }}">
          <br />
          <span class="text-muted small">Optional comma-separated tags, such as "snowboard, winter gear".</span>
        </td>
      </tr>
      <tr>
        <td>
          <label for="photo">Update Photo?</label>
        </td>
        <td>
          <input type="file" name="photo" />
        </td>
      </tr>
    </table>
    <p><label for="description">Description:</label><br />
      <textarea name="description" id="description">{{ request.form.get('description', item['description'] or '') }}</textarea>
    </p>

    <input type="submit" value="Save">
  </form>
    <a href="{{ url_for('items.details', id=item['id']) }}">Cancel</a><br />

{% endif %}
  {% endblock %}
