{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import page_header %}

{% block title %}Add New Item{% endblock %}
{% block header %}{{ page_header('Add New Item') }}{% endblock %}

{% block content %}
{% if places|length < 1 %}
<div class="alert alert-danger">You have not defined any places yet. <a href="{{ url_for('places.create') }}">Add a place first</a>.</div>
{% else %}
<form method="post" enctype="multipart/form-data" class="card">
  <div class="card-body">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
    <div class="row g-3">
      <div class="col-md-8">
        <label for="name" class="form-label">Name <span class="text-danger">*</span></label>
        <input name="name" class="form-control" autofocus id="name" value="{{ request.form.get('name', '') }}" required>
      </div>
      <div class="col-md-4">
        <label for="serial_no" class="form-label">Serial #</label>
        <input name="serial_no" class="form-control" autocomplete="off" id="serial_no" value="{{ request.form.get('serial_no', '') }}">
      </div>
      <div class="col-md-3">
        <label for="qty" class="form-label">Quantity <span class="text-danger">*</span></label>
        <input name="qty" type="number" class="form-control" id="qty" value="{{ request.form.get('qty', '') }}" required>
      </div>
      <div class="col-md-4">
        <label for="unit_id" class="form-label">Unit</label>
        <select name="unit_id" id="unit_id" class="form-select">
          <option value="">— None —</option>
          {% for u in units %}
          <option value="{{ u.id }}" {% if request.form.get('unit_id') == u.id|string %}selected{% endif %}>{{ u.label }}</option>
          {% endfor %}
        </select>
        {% if can_create_item(g.user) %}
        <div class="form-text"><a class="action" href="{{ url_for('units.create', embed=1) }}" id="add-unit-link">Add a unit</a></div>
        {% endif %}
      </div>
      <div class="col-md-3">
        <label for="cost" class="form-label">Cost</label>
        <input name="cost" class="form-control currency" type="number" id="cost" min="0.01" step="0.01" value="{{ request.form.get('cost', '') }}">
      </div>
      <div class="col-md-4">
        <label for="date_acquired" class="form-label">Date acquired</label>
        <input name="date_acquired" type="date" class="form-control" id="date_acquired"
          value="{{ request.form.get('date_acquired', today) }}">
      </div>
      <div class="col-md-8">
        <label for="place_id" class="form-label">Place <span class="text-danger">*</span></label>
        <select name="place_id" id="place_id" class="form-select" required>
          <option value="">— Select —</option>
          {% for p in places %}
          <option value="{{ p.id }}">{{ p.label }}</option>
          {% endfor %}
        </select>
        {% if can_create_place(g.user) %}
        <div class="form-text"><a class="action" href="{{ url_for('places.create', embed=1) }}" id="add-place-link">Add a place</a></div>
        {% endif %}
      </div>
      <div class="col-12">
        <label for="sublocation" class="form-label">Sublocation</label>
        <input name="sublocation" class="form-control" id="sublocation" value="{{ request.form.get('sublocation', '') }}">
        <div class="form-text">Optional detail inside the selected place, such as "on top of the dongle".</div>
      </div>
      <div class="col-12">
        <label for="tags" class="form-label">Tags</label>
        <input name="tags" class="form-control" id="tags" value="{{ request.form.get('tags', '') }}">
        <div class="form-text">Optional comma-separated tags, such as "snowboard, winter gear".</div>
      </div>
      <div class="col-12">
        <label for="description" class="form-label">Description <span class="text-danger">*</span></label>
        <textarea name="description" class="form-control" id="description" rows="4" required>{{ request.form.get('description', '') }}</textarea>
      </div>
      <div class="col-12">
        <label for="photos" class="form-label">Photos</label>
        <input type="file" name="photos" class="form-control" id="photos" accept="image/*" multiple>
        <div class="form-text">Up to 10 images. First photo is the cover thumbnail.</div>
      </div>
    </div>
  </div>
  <div class="card-footer d-flex gap-2">
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="{{ url_for('items.index') }}" class="btn btn-theme-outline">Cancel</a>
  </div>
</form>
{% include 'items/_place_modal.html.j2' %}
{% include 'items/_unit_modal.html.j2' %}
{% endif %}
{% endblock %}
