{% extends 'base.html.j2' %}

{% block header %}
<h1>{% block title %}Add New Item{% endblock %}</h1>
{% endblock %}

{% block content %}
{% if places|length < 1 %} You have not defined any places yet. <a href="{{ url_for('places.create') }}">Add a place first</a>.
{% else %}
  <form method="post" enctype="multipart/form-data">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
    <table class="table table-borderless table-dark">
      <tr>
        <td><label for="name">Name:</label></td>
        <td><input name="name" autofocus="autofocus" id="name" value="{{ request.form.get('name', '') }}" required></td>
      </tr>
      <tr>
        <td><label for="serial_no">Serial #:</label></td>
        <td><input name="serial_no" autocomplete="off" id="serial_no" value="{{ request.form.get('serial_no', '') }}"></td>
      </tr>
      <tr>
        <td>
          <label for="qty">Quantity:</label>
        </td>
        <td>
          <input name="qty" type="number" id="qty" value="{{ request.form.get('qty', '') }}" required>
        </td>
      </tr>
      <tr>
        <td>
          <label for="cost">Cost:</label>
        </td>
          <td><input name="cost" class="currency" type="number" id="cost" min="0.01" step="0.01" value="{{ request.form.get('cost', '') }}"></td>
      </tr>
      <tr>
        <td>
          <label for="place_id">Place:</label>
        </td>
        <td>
          <select name="place_id" id="place_id" required>
            <option value="">— Select —</option>
            {% for p in places %}
            <option value="{{ p.id }}">{{ p.label }}</option>
            {% endfor %}
          </select>
          <br />
          <a class="action" href="{{ url_for('places.create') }}">Add a place</a>
        </td>
      </tr>
      <tr>
        <td>
          <label for="sublocation">Sublocation:</label>
        </td>
        <td>
          <input name="sublocation" id="sublocation" value="{{ request.form.get('sublocation', '') }}">
          <br />
          <span class="text-muted small">Optional detail inside the selected place, such as "on top of the dongle".</span>
        </td>
      </tr>
      <tr>
        <td>
          <label for="tags">Tags:</label>
        </td>
        <td>
          <input name="tags" id="tags" value="{{ request.form.get('tags', '') }}">
          <br />
          <span class="text-muted small">Optional comma-separated tags, such as "snowboard, winter gear".</span>
        </td>
      </tr>
      <tr>
        <td>
          <label for="photo">Photo:</label>
        </td>
        <td>
          <input type="file" name="photo" />
        </td>
      </tr>
    </table>
    <p><label for="description">Description:</label><br />
      <textarea name="description" id="description">{{ request.form.get('description', '') }}</textarea>
    </p>

    <input type="submit" value="Save">
  </form>
  <a href="{{ url_for('items.index') }}">Cancel</a>

{% endif %}
  {% endblock %}
