{% extends 'base.html.j2' %}

{% block header %}
<h1>{% block title %}Items{% endblock %}</h1>
{% endblock %}

{% block content %}
{% if g.user %}
{% if items|length == 0 or places|length == 0 %}
<ul>
{% if places|length == 0 and can_create_place(g.user) %}<li>You have not yet defined any places. <a href="{{ url_for('places.create') }}">Add a place</a> first (for example a room, then shelves or boxes under it).</li>{% endif %}
{% if places|length == 0 and not can_create_place(g.user) %}<li>There are no places in the database yet.</li>{% endif %}
{% if items|length == 0 and places|length > 0 and can_create_item(g.user) %}<li>There are no items in the database. <a href="{{ url_for('items.create') }}">Add a new item</a></li>{% endif %}
{% if items|length == 0 and places|length > 0 and not can_create_item(g.user) %}<li>There are no items in the database yet.</li>{% endif %}
</ul>
{% else %}
{% if can_create_item(g.user) %}
<p><a href="{{ url_for('items.create') }}">Add a new item</a></p>
{% endif %}

<p>There {% if items|length > 1 %} are {% else %} is {% endif %} {{ items|length }} item{% if items|length > 1 %}s{% endif %} in the database. Here are the most recent entries:</p>
<table class="table table-borderless table-dark">
  <thead>
    <tr class="table-primary">
      <th>Item</th>
      <th>Location</th>
      <th>Tags</th>
      {% if g.user %}
      <th>Actions</th>
      {% endif %}
    </tr>
  </thead>
  <tbody>
    {% for item in items %}
    <tr>
      <td>
      <img src="{% if item['photo'] %}{{ url_for('static', filename='photos/'+item['photo']) }}{% else %}{{ url_for('static', filename='no_image.png') }}{% endif %}" class="img-thumbnail img-fluid" style="max-height: 50px; max-width: 50px;">&nbsp;&nbsp;&nbsp;
      <A HREF="{{ url_for('items.details', id=item['id']) }}">{{ item.name }}</A></td>
      <td>{{ item.location_path }}</td>
      <td>{{ item.tag_list }}</td>
      {% if g.user %}
      <td>
        {% if can_edit_item(g.user, item) %}
        <a href="{{ url_for('items.update', id=item['id']) }}">Edit</a>&nbsp;&nbsp;
        {% endif %}
        {% if can_delete_item(g.user, item) %}
        <form method="post" action="{{ url_for('items.delete', id=item['id']) }}" class="d-inline" onsubmit="return confirm('Are you sure?');">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
          <button type="submit" class="btn btn-link p-0 align-baseline">Delete</button>
        </form>
        {% endif %}
      </td>
      {% endif %}
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
{% else %}
<p>Please <A HREF="{{ url_for('auth.login') }}">log in</A> first.</p>
{% endif %}
{% endblock %}
