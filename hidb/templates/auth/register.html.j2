{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import page_header %}

{% block title %}Register{% endblock %}
{% block header %}{{ page_header('Register') }}{% endblock %}

{% block content %}
<div class="card auth-card">
  <div class="card-body">
    <form method="post">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input name="username" class="form-control" autocapitalize="none" autofocus id="username" required>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input type="password" class="form-control" autocapitalize="none" name="password" id="password" required>
      </div>
      <button type="submit" class="btn btn-primary w-100">Register</button>
    </form>
  </div>
  <div class="card-footer text-center text-muted small">
    Already have an account? <a href="{{ url_for('auth.login') }}">Log in</a>
  </div>
</div>
{% endblock %}
