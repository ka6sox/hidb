{% extends 'base.html.j2' %}

{% block header %}
  <h1>{% block title %}Users{% endblock %}</h1>
{% endblock %}

{% block content %}
<table class="table table-borderless table-dark">
  <thead>
    <tr class="table-primary">
      <th>Username</th>
      <th>Role</th>
      <th>Editor for</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {% for user in users %}
    <tr>
      <td>{{ user.username }}{% if user.id == original_owner_id %} (original Owner){% endif %}</td>
      <td>{{ role_label(user.role) }}</td>
      <td>{{ user.editor_for.username if user.editor_for else '' }}</td>
      <td>{{ 'Active' if user.is_active else 'Disabled' }}</td>
      <td>
        {% if user.id != original_owner_id and user.is_active %}
        <form method="post" action="{{ url_for('auth.update_user_role', user_id=user.id) }}" class="mb-2">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
          <select name="role">
            {% for role in roles %}
            <option value="{{ role }}" {% if user.role == role %}selected{% endif %}>{{ role_label(role) }}</option>
            {% endfor %}
          </select>
          <select name="editor_for_id">
            <option value="">Editor sponsor</option>
            {% for sponsor in sponsor_options %}
            <option value="{{ sponsor.id }}" {% if user.editor_for_id == sponsor.id %}selected{% endif %}>{{ sponsor.username }}</option>
            {% endfor %}
          </select>
          <button type="submit">Update role</button>
        </form>
        {% endif %}

        {% if g.user.role == 'owner' %}
        <a href="{{ url_for('auth.reset_user_password', user_id=user.id) }}">Reset password</a>
        {% if user.id != original_owner_id %}
        <form method="post" action="{{ url_for('auth.update_user_active', user_id=user.id) }}" class="d-inline">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
          <input type="hidden" name="is_active" value="{{ '0' if user.is_active else '1' }}">
          <button type="submit">{{ 'Disable' if user.is_active else 'Enable' }}</button>
        </form>
        {% endif %}
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endblock %}
