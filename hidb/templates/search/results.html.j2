{% extends 'base.html.j2' %}

{% block header %}
  <h1>{% block title %}Search Results{% endblock %}</h1>
{% endblock %}

{% block content %}
<p>Found {{ results|length }} result{% if results|length > 1 %}s{% endif %}.</p>

<table class="table table-borderless table-dark">
<thead>
<tr class="table-primary">
<th>Item</th>
      <th>Qty</th>
      <th>Location</th>
      {% if g.user %}
      <th>Actions</th>
      {% endif %}
</thead>
  <tbody>
    {% for r in results %}
    <tr>
    <td><img src="{% if r['photo'] %}{{ url_for('static', filename='photos/'+r['photo']) }}{% else %}{{ url_for('static', filename='no_image.png') }}{% endif %}" class="img-thumbnail img-fluid" style="max-height: 50px; max-width: 50px;">&nbsp;&nbsp;&nbsp;
    <A HREF="{{ url_for('items.details', id=r['id']) }}">{{ r['name'] }}</A></td>
    <td>{{ r['qty'] }}</td>
    <td>{{ r.place_path }}</td>
      {% if g.user %}
      <td><a href="{{ url_for('items.update', id=r['id']) }}">Edit</a>&nbsp;&nbsp;
        <a href="{{ url_for('items.delete', id=r['id']) }}" onclick="return confirm('Are you sure?');">Delete</a>
      </td>
      {% endif %}

    </tr>
    {% endfor %}
  </tbody>
</table>

<p><a class="action" href="{{ url_for('search.index') }}">Search Again</a></p>

{% endblock %}
