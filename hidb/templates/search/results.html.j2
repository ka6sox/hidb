{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import page_header, item_thumb %}

{% block title %}Search Results{% endblock %}
{% block header %}{{ page_header('Search results', results|length ~ ' match' ~ ('es' if results|length != 1 else '')) }}{% endblock %}

{% block content %}
<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Item</th>
          <th>Qty</th>
          <th>Location</th>
          <th>Tags</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for r in results %}
        <tr>
          <td class="align-middle">
            <div class="d-flex align-items-center gap-2">
              {{ item_thumb(r.photo, r.name) }}
              <a href="{{ url_for('items.details', id=r['id']) }}">{{ r['name'] }}</a>
            </div>
          </td>
          <td class="align-middle">{{ r['qty'] }}</td>
          <td class="align-middle text-muted">{{ r.location_path }}</td>
          <td class="align-middle small">{{ r.tag_list }}</td>
          <td class="align-middle">
            {% if can_edit_item(g.user, r) %}
            <a href="{{ url_for('items.update', id=r['id']) }}" class="btn btn-sm btn-theme-outline">Edit</a>
            {% endif %}
            {% if can_delete_item(g.user, r) %}
            <form method="post" action="{{ url_for('items.delete', id=r['id']) }}" class="d-inline" onsubmit="return confirm('Are you sure?');">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
              <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
            </form>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<div class="mt-3 d-flex gap-3">
  <form action="{{ url_for('search.run_search') }}" method="post" class="d-inline">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
    <input type="hidden" name="q" value="{{ q }}">
    {% for pid in selected_places %}
    <input type="hidden" name="places" value="{{ pid }}">
    {% endfor %}
    {% if include_subtree %}
    <input type="hidden" name="search_place_subtree" value="search_place_subtree">
    {% endif %}
    <button type="submit" class="btn btn-theme-outline btn-sm">Search again</button>
  </form>
  <a href="{{ url_for('search.index', q=q) }}" class="btn btn-link btn-sm">New search</a>
</div>
{% endblock %}
