{% extends 'base.html.j2' %}

{% block header %}
<h1>{% block title %}Find{% endblock %}</h1>
{% endblock %}

{% block content %}
{% if g.user %}
{% if places|length < 1 %}
<p>You have not defined any places yet. <a href="{{ url_for('places.create') }}">Add a place first</a>.</p>
{% else %}
  <form action="{{ url_for('search.run_search') }}" method="post">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">

    <table class="table table-borderless table-dark">
      <tbody>
        <tr>
          <td><input type="checkbox" name="search_name" value="search_name">&nbsp;&nbsp;&nbsp;<label for="name">Name:</label></td>
          <td><input name="name" autofocus id="name"></td>
        </tr>

        <tr>
          <td><input type="checkbox" name="search_description" value="search_description">&nbsp;&nbsp;&nbsp;
          <label for="description">Description:</label></td>
          <td><input name="description" id="description"></td>
        </tr>

        <tr>
          <td><input type="checkbox" name="search_sublocation" value="search_sublocation">&nbsp;&nbsp;&nbsp;
          <label for="sublocation">Sublocation:</label></td>
          <td><input name="sublocation" id="sublocation"></td>
        </tr>

        <tr>
          <td><input type="checkbox" name="search_tags" value="search_tags">&nbsp;&nbsp;&nbsp;
          <label for="tags">Tags:</label></td>
          <td><input name="tags" id="tags"></td>
        </tr>

        <tr>
          <td><input type="checkbox" name="search_places" value="search_places">&nbsp;&nbsp;&nbsp;
          <label for="places">Place(s):</label></td>
          <td>
            <select name="places" id="places" multiple size="6">
              {% for p in places %}
              <option value="{{ p.id }}">{{ p.label }}</option>
              {% endfor %}
            </select>
          </td>
        </tr>

        <tr>
          <td><input type="checkbox" name="search_place_subtree" value="search_place_subtree">&nbsp;&nbsp;&nbsp;
          <label for="search_place_subtree_hint">Include nested places</label></td>
          <td><span class="text-muted small">When checked, matches items under selected places too (children in the tree).</span></td>
        </tr>

        <tr>
          <td><input type="checkbox" name="search_serial_no" value="search_serial_no">&nbsp;&nbsp;&nbsp;
          <label for="serial_no">Serial #:</label></td>
          <td><input name="serial_no" id="serial_no"></td>
        </tr>
      </tbody>
    </table>
    <input class="submit" type="submit" value="Search">
  </form>
{% endif %}
{% else %}
<p>Please <A HREF="{{ url_for('auth.login') }}">log in</A> first.</p>
{% endif %}
  {% endblock %}
