{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import page_header %}

{% block title %}Find{% endblock %}
{% block header %}{{ page_header('Find items') }}{% endblock %}

{% block content %}
{% if g.user %}
{% if places|length < 1 %}
<div class="alert alert-danger">You have not defined any places yet. <a href="{{ url_for('places.create') }}">Add a place first</a>.</div>
{% else %}
<div class="card">
  <div class="card-body">
    <form action="{{ url_for('search.run_search') }}" method="post">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
      <div class="mb-3">
        <label for="q" class="form-label">Search</label>
        <div class="input-group">
          <input type="search" name="q" id="q" class="form-control" autofocus
            placeholder="Search name, description, tags, location…"
            value="{{ q }}">
          <button type="submit" class="btn btn-primary">Search</button>
        </div>
        <div class="form-text">Partial matches across all fields. Multiple words match if any word matches.</div>
      </div>
      <details {% if selected_places or include_subtree %}open{% endif %}>
        <summary class="mb-3">Optional filters</summary>
        <div class="mb-3">
          <label for="places" class="form-label">Place(s)</label>
          <select name="places" id="places" class="form-select" multiple size="6">
            {% for p in places %}
            <option value="{{ p.id }}" {% if p.id in selected_places %}selected{% endif %}>{{ p.label }}</option>
            {% endfor %}
          </select>
          <div class="form-check mt-2">
            <input type="checkbox" class="form-check-input" name="search_place_subtree" id="search_place_subtree"
              value="search_place_subtree" {% if include_subtree %}checked{% endif %}>
            <label class="form-check-label" for="search_place_subtree">Include nested places</label>
          </div>
          <div class="form-text">When checked, matches items under selected places too (children in the tree).</div>
        </div>
      </details>
    </form>
  </div>
</div>
{% endif %}
{% else %}
<p>Please <a href="{{ url_for('auth.login') }}">log in</a> first.</p>
{% endif %}
{% endblock %}
