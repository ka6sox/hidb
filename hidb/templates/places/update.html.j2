{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import page_header %}

{% block title %}Edit "{{ place['name'] }}"{% endblock %}
{% block header %}{{ page_header('Edit place', place.path) }}{% endblock %}

{% block content %}
<form method="post" class="card">
  <div class="card-body">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
    <div class="mb-3">
      <label for="name" class="form-label">Name</label>
      <input name="name" id="name" class="form-control" autofocus required
        value="{{ request.form.get('name', place['name']) }}">
    </div>
    <div class="mb-3">
      <label for="description" class="form-label">Notes</label>
      <textarea name="description" id="description" class="form-control" rows="3">{{ request.form.get('description', place['description'] or '') }}</textarea>
    </div>
    <div class="form-check mb-3">
      <input type="checkbox" class="form-check-input" name="is_private" id="is_private" value="1"
        {% if request.form.get('is_private', '1' if place['is_private'] else '0') == '1' %}checked{% endif %}>
      <label class="form-check-label" for="is_private">Private place</label>
      <div class="form-text">Only users in this place's sponsorship line can see it when private.</div>
    </div>
  </div>
  <div class="card-footer d-flex gap-2 flex-wrap">
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="{{ url_for('places.index') }}" class="btn btn-theme-outline">Cancel</a>
    <a class="action text-danger ms-auto align-self-center" href="{{ url_for('places.delete', id=place['id']) }}">Delete this place…</a>
  </div>
</form>
{% endblock %}
