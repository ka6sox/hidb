{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import page_header %}

{% block title %}Delete place{% endblock %}
{% block header %}{{ page_header('Delete place', place.path) }}{% endblock %}

{% block content %}
<div class="card">
  <div class="card-body">
    {% if blocked %}
    <p>You cannot delete this place yet.</p>
    <ul>
      {% if child_count > 0 %}<li>It has {{ child_count }} child place(s). Delete or move those first.</li>{% endif %}
      {% if item_count > 0 %}<li>{{ item_count }} item(s) are stored here. Move or delete those items first.</li>{% endif %}
    </ul>
    {% else %}
    <p>Are you sure you want to delete <strong>{{ place.name }}</strong>?</p>
    <form method="post" class="mt-3">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
      <button type="submit" class="btn btn-danger">Delete permanently</button>
    </form>
    {% endif %}
  </div>
  <div class="card-footer">
    <a href="{{ url_for('places.index') }}" class="btn btn-outline-light">{% if blocked %}Back to places{% else %}Cancel{% endif %}</a>
  </div>
</div>
{% endblock %}
